# Копируй в .env и заполни значения

# App
APP_BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:secret@localhost:5432/construction

# JWT — сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-256-bit-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_FROM=СтройКонтроль <noreply@example.com>
EMAIL_PROVIDER=log
RESEND_API_KEY=

# Embeddings / OpenRouter
OPENROUTER_API_KEY=
# legacy fallback:
openrouter_API=
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# S3 (опционально, для вложений)
S3_BUCKET=construction-files
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=
S3_SECRET_KEY=

# CORS — через запятую
CORS_ORIGINS=["http://localhost:3000"]
